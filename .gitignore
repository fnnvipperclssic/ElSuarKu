# ================================================================
# ElSuarKu — .gitignore
# Melindungi data sensitif & file lokal dari upload ke GitHub
# ================================================================

# --- Android / Gradle ---
*.iml
.gradle
/local.properties
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# --- IDE (Android Studio / IntelliJ) ---
# Abaikan semua .idea kecuali konfigurasi shared
.idea/
!.idea/codeStyles/
!.idea/codeStyles/**
!.idea/runConfigurations/
!.idea/runConfigurations/**
!.idea/.gitignore

# --- Firebase — DATA SENSITIF (API keys, OAuth IDs) ---
app/google-services.json
**/google-services.json
*.logcat

# --- Android Signing Keys ---
*.keystore
*.jks
*.p12
*.pfx
app/keystore.properties
app/signing.properties

# --- Environment / Secrets ---
*.env
*.env.local
secrets/
**/secrets.*
**/credentials.*
**/secret.properties
**/secrets.properties

# --- OS files ---
Thumbs.db
*.swp
*.swo
*~
.vscode/

# --- Log & Debug ---
*.log
*.logcat
logs/
*.hprof
*.trace

# --- Build outputs (release APK/AAB tidak di-commit) ---
app/release/
*.apk
*.aab
*.ap_

# --- Testing ---
/test-results/
/test-output/

# --- Misc tool outputs ---
.metals/
.bloop/
.bsp/
