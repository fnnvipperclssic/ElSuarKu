# ================================================================
# ElSuarKu — .gitignore
# Melindungi data sensitif & file lokal dari upload ke GitHub
# ================================================================

# --- Android / Gradle ---
*.iml
.gradle
/local.properties
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# --- IDE (Android Studio / IntelliJ) ---
# Abaikan semua .idea kecuali konfigurasi shared
.idea/
!.idea/codeStyles/
!.idea/codeStyles/**
!.idea/runConfigurations/
!.idea/runConfigurations/**
!.idea/.gitignore

# --- Firebase — DATA SENSITIF (API keys, OAuth IDs) ---
app/google-services.json
**/google-services.json
*.logcat

# --- Android Signing Keys ---
*.keystore
*.jks
*.p12
*.pfx
app/keystore.properties
app/signing.properties

# --- Environment / Secrets ---
*.env
*.env.local
secrets/
**/secrets.*
**/credentials.*
**/secret.properties
**/secrets.properties

# --- OS files ---
Thumbs.db
*.swp
*.swo
*~
.vscode/

# --- Log & Debug ---
*.log
*.logcat
logs/
*.hprof
*.trace

# --- Build outputs (release APK/AAB tidak di-commit) ---
app/release/
*.apk
*.aab
*.ap_

# --- Testing ---
/test-results/
/test-output/

# --- Misc tool outputs ---
.metals/
.bloop/
.bsp/

# --- Firebase Cloud Functions ---
functions/node_modules/
functions/lib/
functions/.env

# --- Claude Code / AI Tools ---
.claude/
.memory/
CLAUDE.md
MEMORY.md
.playwright-mcp/

# --- AI-generated documentation (jangan di-commit) ---
ANALISIS_*.md
CHANGELOG.md
CONTRIBUTING.md
PHASE_IMPLEMENTATION.md
Panduan_*.md
SECURITY.md
app/ElSuarKu_Project.md

# --- Screenshots & Emulator ---
emu_*.png
*.screenshot.png
screenshots/
