# ================================================================
# ElSuarKu — .gitignore
# Melindungi data sensitif & file lokal dari upload ke GitHub
# ================================================================

# --- Android / Gradle ---
*.iml
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
/.idea/deploymentTargetSelector.xml
/.idea/appInsightsSettings.xml
/.idea/deviceManager.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# --- Firebase — DATA SENSITIF (API keys, OAuth IDs) ---
app/google-services.json
**/google-services.json

# --- Claude Code / AI Tools ---
.claude/
**/.claude/
*.logcat

# --- Android Signing Keys ---
*.keystore
*.jks
*.p12
*.pfx
app/keystore.properties
app/signing.properties

# --- Environment / Secrets ---
*.env
*.env.local
secrets/
**/secrets.*
**/credentials.*

# --- OS files ---
Thumbs.db
*.swp
*.swo
*~
.vscode/

# --- Log files ---
*.log
*.logcat
logs/
